# API Configuration
VITE_API_URL=https://api.g00pay.com

# Cloudflare Turnstile (Bot Protection)
# Get your site key from: https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAAxXXXXXXXXXXX

# Cloudflare R2 (File Storage for KYC Documents)
VITE_R2_API_BASE=https://api.g00pay.com
VITE_R2_PUBLIC_URL=https://files.g00pay.com

# App Configuration
VITE_APP_NAME="Dubai Exchange"
VITE_APP_URL=https://g00pay.com

# Optional: Analytics
# VITE_ANALYTICS_ID=
